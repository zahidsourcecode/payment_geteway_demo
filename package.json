{
  "name": "payment-gateway-demo",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "typecheck": "vue-tsc --noEmit"
  },
  "dependencies": {
    "@stripe/stripe-js": "^5.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "pinia": "^2.3.1",
    "stripe": "^17.7.0",
    "vue": "^3.5.40",
    "vue-router": "^4.5.1",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.4",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-vue": "^5.2.3",
    "concurrently": "^9.1.2",
    "tailwindcss": "^4.1.4",
    "typescript": "~5.8.3",
    "vite": "^6.2.5",
    "vue-tsc": "^2.2.8"
  }
}
